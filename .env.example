# =============================================================
# Umgebungsvariablen für das Wetter-Dashboard
# =============================================================
# Kopiere diese Datei zu ".env.local" und trage deinen
# persönlichen API-Schlüssel ein:
#
#   cp .env.example .env.local
#
# Den kostenlosen API-Schlüssel erhältst du unter:
#   https://home.openweathermap.org/users/sign_up
# -------------------------------------------------------------

# Dein OpenWeatherMap API-Schlüssel (Pflichtfeld)
OPENWEATHER_API_KEY=dein_api_schluessel_hier
